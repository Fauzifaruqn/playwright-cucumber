{
  "name": "saucedemo-cucumber",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "clean": "node cleanup.js",
    "test": "node run-tests.js",
    "test:smoke": "node run-tests.js --tags @smoke",
    "test:negative": "node run-tests.js --tags @negative",
    "test:failure-demo": "node run-tests.js --tags @demo-failure",
    "test:serial": "node run-tests.js --parallel 1",
    "test:feature": "node run-tests.js --paths",
    "test:dry": "npx cucumber-js --dry-run",
    "report": "node generate-report.js"
  },
